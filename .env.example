# 复制为 .env 后填入真实值（.env 已被 .gitignore 忽略）

# ---- MySQL (docker-compose 默认值) ----
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=blog
DB_PASSWORD=blogpass
DB_NAME=blogbook

# ---- 抓取礼貌策略 ----
HTTP_USER_AGENT=blogbook-archiver/1.0 (personal bilingual book project)
FETCH_MIN_DELAY=1.5          # 每次请求之间的最小间隔(秒)
FETCH_MAX_DELAY=3.0          # 最大间隔(秒)，区间内随机，避免规律性压力
FETCH_TIMEOUT=30
FETCH_MAX_RETRIES=4

# ---- MiniMax-M3 翻译（Anthropic 兼容接口）----
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-replace-me
TRANSLATE_MODEL=MiniMax-M3
TRANSLATE_CONCURRENCY=4      # 3~5 之间
TRANSLATE_MAX_TOKENS=32768   # token 充足，放开输出上限以容纳长文整块翻译

# ---- 本地播客 ASR（可选，仅 a16z 播客来源用）----
# 指向装有 mlx_qwen3_asr 的 Python 解释器（Apple MLX）
ASR_PYTHON=python3
ASR_MODEL=Qwen/Qwen3-ASR-1.7B
